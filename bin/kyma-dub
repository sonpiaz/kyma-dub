#!/usr/bin/env bash
# kyma-dub — time-aligned AI video dubbing, all on one Kyma key.
#
#   kyma-dub <video> [options]        dub a video into another language
#   kyma-dub models                   translation-capable models on Kyma now
#   kyma-dub voices [filters]         available voices + gender/age/use-case
#   kyma-dub preview <voice>          hear a voice sample
#   kyma-dub recommend --for "..."    suggest a voice (+model) for a profile
#   kyma-dub whatsnew                 what Kyma added since last check
#
# Examples:
#   kyma-dub talk.mp4                          # auto -> English, voice charlie
#   kyma-dub talk.mp4 --to es --voice rachel   # dub to Spanish
#   kyma-dub voices --gender female --age young --use-case social_media
#   kyma-dub recommend --for "young female, energetic, for TikTok" --smart
#
# See README.md for routing + fallback details.

set -euo pipefail

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/env.sh
source "$SELF_DIR/lib/env.sh"

# ── discovery subcommands route to lib/discover.py ──
case "${1:-}" in
  models|voices|preview|recommend|whatsnew)
    exec python3 "$SELF_DIR/lib/discover.py" "$@"
    ;;
  setup-ffmpeg)
    # Download a libass-enabled static ffmpeg (for --burn) without touching system ffmpeg.
    DEST="$HOME/.kyma-dub/bin"; mkdir -p "$DEST"
    if [[ "$(uname -s)" == "Darwin" && "$(uname -m)" == "arm64" ]]; then
      echo "[kyma-dub] downloading libass-enabled ffmpeg (macOS arm64)…"
      if curl -fsSL --max-time 120 "https://www.osxexperts.net/ffmpeg71arm.zip" -o /tmp/kdff.zip; then
        unzip -o -q /tmp/kdff.zip -d "$DEST" && chmod +x "$DEST/ffmpeg" && xattr -d com.apple.quarantine "$DEST/ffmpeg" 2>/dev/null
        rm -rf "$DEST/__MACOSX" /tmp/kdff.zip
        "$DEST/ffmpeg" -hide_banner -filters 2>/dev/null | grep -q ' ass ' \
          && echo "[kyma-dub] ✓ installed $DEST/ffmpeg (has libass) — --burn ready" \
          || echo "[kyma-dub] ⚠ downloaded but libass not detected"
      else
        echo "[kyma-dub] download failed. Get a libass ffmpeg manually and set KYMA_DUB_FFMPEG." >&2; exit 1
      fi
    else
      echo "[kyma-dub] auto-setup is macOS/arm64 only. On Linux, system ffmpeg usually has libass"
      echo "  (apt install ffmpeg). Otherwise point KYMA_DUB_FFMPEG to a libass-enabled ffmpeg."
    fi
    exit 0
    ;;
  --version) echo "$KYMA_DUB_VERSION_STRING"; exit 0 ;;
esac

# ── subs subcommand: translated subtitles (.srt/.vtt) ──
if [[ "${1:-}" == "subs" ]]; then
  shift
  S_FROM="auto"; S_TO="en"; S_MODEL="qwen-3.7-max"; S_OUT=""; S_FMT="srt"; S_VIDEO=""; S_BILINGUAL=0; S_BURN=0
  while (($# > 0)); do
    case "$1" in
      --from) S_FROM="$2"; shift 2 ;;
      --to) S_TO="$2"; shift 2 ;;
      --model) S_MODEL="$2"; shift 2 ;;
      --out) S_OUT="$2"; shift 2 ;;
      --format) S_FMT="$2"; shift 2 ;;
      --bilingual) S_BILINGUAL=1; shift ;;
      --burn) S_BURN=1; shift ;;
      -h|--help) echo "Usage: kyma-dub subs <video> [--from <lang>] [--to <lang>] [--bilingual] [--burn] [--format srt|vtt|both] [--out <path-without-ext>]"; exit 0 ;;
      -*) echo "[kyma-dub] unknown flag: $1" >&2; exit 64 ;;
      *) S_VIDEO="$1"; shift ;;
    esac
  done
  [[ -z "$S_VIDEO" ]] && { echo "[kyma-dub] usage: kyma-dub subs <video> [--to <lang>]" >&2; exit 64; }
  [[ -f "$S_VIDEO" ]] || { echo "[kyma-dub] file not found: $S_VIDEO" >&2; exit 66; }
  for cmd in ffmpeg ffprobe curl python3; do command -v "$cmd" >/dev/null 2>&1 || { echo "[kyma-dub] missing dependency: $cmd" >&2; exit 1; }; done
  kyma_dub_keys_check || exit 1
  if [[ -z "$S_OUT" ]]; then
    dir="$(dirname "$S_VIDEO")"; base="$(basename "${S_VIDEO%.*}")"
    S_OUT="$dir/$base.$S_TO"
  fi
  CFG="$(mktemp -t kyma-subs-cfg.XXXXXX.json)"
  trap 'rm -f "$CFG"' EXIT
  python3 - "$CFG" <<PY
import json,sys,os
json.dump({
 "video": os.path.abspath("$S_VIDEO"),
 "out_base": os.path.abspath("$S_OUT"),
 "mode": "$KYMA_DUB_MODE",
 "kyma_base": "$KYMA_DUB_BASE",
 "kyma_key": os.environ.get("KYMA_API_KEY",""),
 "groq_key": os.environ.get("GROQ_API_KEY",""),
 "ua": "$KYMA_DUB_USER_AGENT",
 "source_lang": "$S_FROM",
 "target_lang": "$S_TO",
 "translate_model": "$S_MODEL",
 "format": "$S_FMT",
 "bilingual": bool($S_BILINGUAL),
 "burn": bool($S_BURN),
}, open(sys.argv[1],"w"))
PY
  python3 "$SELF_DIR/lib/subs.py" "$CFG"
  exit $?
fi

# ── dub defaults ──
SOURCE_LANG="auto"
TARGET_LANG="en"
VOICE="charlie"
TTS="kyma"
TRANSLATE_MODEL="qwen-3.7-max"
MAX_SPEED="1.5"
CHUNK_SEC="22"
OUT=""
KEEP_TEMP=0
ALLOW_VOICE_FALLBACK=0
BURN=0
SRT=0
BILINGUAL=0

usage() {
  cat <<'EOF'
kyma-dub — time-aligned AI video dubbing (one Kyma key)

Usage:
  kyma-dub <video> [options]
  kyma-dub models | voices | preview | recommend | whatsnew

Dub options:
  --from <lang>            source language code (default: auto-detect)
  --to <lang>              target language code (default: en)
  --voice <name|id>        charlie|will|liam|brian|rachel|adam|jessica
                           or a raw ElevenLabs voice id (default: charlie)
  --tts <engine>           kyma (default — one key, eleven-v3) | elevenlabs
  --model <id>             translation model (default: qwen-3.7-max)
  --max-speed <n>          max voice speed-up to fit a slot (default: 1.5).
                           Never slowed below 1.0 — leftover time = a pause.
  --chunk-sec <n>          max seconds per dub chunk (default: 22).
  --allow-voice-fallback   permit an independent MiniMax voice if every
                           ElevenLabs path is down (CHANGES the voice)
  --srt                    also write a .srt timed to the dubbed audio
  --bilingual              add bilingual captions: target on top, cleaned
                           source smaller + dimmer below (pair with --burn)
  --burn                   burn the captions into the output video
                           (needs libass ffmpeg — run `kyma-dub setup-ffmpeg`)
  --out <path>             output file (default: "<name> [<LANG> dub].mp4")
  --keep-temp              keep intermediate files
  --version / -h

Discovery (the live "door" — query current models/voices):
  kyma-dub models [--json]
  kyma-dub voices [--gender --age --use-case --accent --lang --library] [--json]
  kyma-dub preview <voice|id> ["sample text"]
  kyma-dub recommend --for "<need>" [--smart] [--library] [--json]
  kyma-dub whatsnew

Routing: transcribe + translate + TTS all on one Kyma key (eleven-v3).
TTS chain (locked per job to keep one voice): Kyma eleven-v3 -> Kyma v2
-> ElevenLabs v3 direct -> v2 direct -> Kyma minimax (voice changes; opt-in).
EOF
}

# ── parse args ──
VIDEO=""
while (($# > 0)); do
  case "$1" in
    --from) SOURCE_LANG="$2"; shift 2 ;;
    --to) TARGET_LANG="$2"; shift 2 ;;
    --voice) VOICE="$2"; shift 2 ;;
    --tts) TTS="$2"; shift 2 ;;
    --model) TRANSLATE_MODEL="$2"; shift 2 ;;
    --max-speed) MAX_SPEED="$2"; shift 2 ;;
    --chunk-sec) CHUNK_SEC="$2"; shift 2 ;;
    --allow-voice-fallback) ALLOW_VOICE_FALLBACK=1; shift ;;
    --burn) BURN=1; shift ;;
    --srt) SRT=1; shift ;;
    --bilingual) BILINGUAL=1; shift ;;
    --out) OUT="$2"; shift 2 ;;
    --keep-temp) KEEP_TEMP=1; shift ;;
    -h|--help) usage; exit 0 ;;
    -*) echo "[kyma-dub] unknown flag: $1" >&2; echo; usage; exit 64 ;;
    *) VIDEO="$1"; shift ;;
  esac
done

[[ -z "$VIDEO" ]] && { usage; exit 64; }
[[ -f "$VIDEO" ]] || { echo "[kyma-dub] file not found: $VIDEO" >&2; exit 66; }

# ── deps ──
missing=()
for cmd in ffmpeg ffprobe curl python3; do
  command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
done
if ((${#missing[@]} > 0)); then
  echo "[kyma-dub] missing dependencies: ${missing[*]}" >&2
  echo "  macOS:  brew install ffmpeg" >&2
  echo "  Debian: sudo apt install ffmpeg curl python3" >&2
  exit 1
fi

kyma_dub_keys_check || exit 1

# ── resolve voice name -> ElevenLabs id ──
VOICE_ID="$(python3 - "$VOICE" <<'PY'
import sys
v=sys.argv[1].strip()
m={"charlie":"IKne3meq5aSn9XLyUdCD","will":"bIHbv24MWmeRgasZH58o","liam":"TX3LPaxmHKxFdv7VOQHJ",
   "brian":"nPczCjzI2devNBz1zQrb","rachel":"21m00Tcm4TlvDq8ikWAM","adam":"pNInz6obpgDQGcFmaJgB",
   "jessica":"cgSgspJ2msm6clMCkdW9"}
print(m.get(v.lower(), v))   # passthrough when already a raw id
PY
)"

# ── default output name ──
if [[ -z "$OUT" ]]; then
  dir="$(dirname "$VIDEO")"; base="$(basename "${VIDEO%.*}")"
  upper_lang="$(echo "$TARGET_LANG" | tr '[:lower:]' '[:upper:]')"
  OUT="$dir/$base [$upper_lang dub].mp4"
fi

# ── build config + run pipeline ──
CFG="$(mktemp -t kyma-dub-cfg.XXXXXX.json)"
trap 'rm -f "$CFG"' EXIT
python3 - "$CFG" <<PY
import json,sys,os
json.dump({
 "video": os.path.abspath("$VIDEO"),
 "out": os.path.abspath("$OUT"),
 "mode": "$KYMA_DUB_MODE",
 "kyma_base": "$KYMA_DUB_BASE",
 "kyma_key": os.environ.get("KYMA_API_KEY",""),
 "groq_key": os.environ.get("GROQ_API_KEY",""),
 "eleven_key": os.environ.get("ELEVENLABS_API_KEY",""),
 "ua": "$KYMA_DUB_USER_AGENT",
 "source_lang": "$SOURCE_LANG",
 "target_lang": "$TARGET_LANG",
 "voice": "$VOICE",
 "voice_id": "$VOICE_ID",
 "minimax_voice": "English_expressive_narrator",
 "tts": "$TTS",
 "translate_model": "$TRANSLATE_MODEL",
 "max_speed": float("$MAX_SPEED"),
 "chunk_sec": float("$CHUNK_SEC"),
 "allow_voice_fallback": bool($ALLOW_VOICE_FALLBACK),
 "burn": bool($BURN),
 "srt": bool($SRT),
 "bilingual": bool($BILINGUAL),
 "keep_temp": bool($KEEP_TEMP),
}, open(sys.argv[1],"w"))
PY

python3 "$SELF_DIR/lib/pipeline.py" "$CFG"
